# niurk smart workflow environment
# Source this file with: set -a; . env/niurk-cluster.env; set +a

NIURK_BUNDLE_VERSION="2026.05.01-smart-workflow"
NIURK_NAMESPACE="rhiz"
NIURK_DOMAIN="niurk.local"

# Safety gates
DRY_RUN="${DRY_RUN:-1}"
ALLOW_DEPLOY="${ALLOW_DEPLOY:-0}"
ALLOW_SOURCE_STOP="${ALLOW_SOURCE_STOP:-0}"
ALLOW_VM_RESTART="${ALLOW_VM_RESTART:-0}"
ALLOW_GPU_MUTATION="${ALLOW_GPU_MUTATION:-0}"
FIDO_REQUIRED="${FIDO_REQUIRED:-0}"
CUTOVER_TOKEN="${CUTOVER_TOKEN:-}"

# LXD access
LXD_REMOTE="${LXD_REMOTE:-local}"
LXD_PROJECT="${LXD_PROJECT:-default}"

# Cluster nodes from provided state
CLUSTER_NODES="ark-rhiz factau-rhiz rhiz-ueth rhiz-woute sigmo-rhiz umowt-rhiz"
ARK_RHIZ_IP="192.168.0.40"
FACTAU_RHIZ_IP="192.168.0.4"
RHIZ_UETH_IP="192.168.0.2"
RHIZ_WOUTE_IP="192.168.0.33"
SIGMO_RHIZ_IP="192.168.0.34"
UMOWT_RHIZ_IP="192.168.0.36"

DB_LEADER_NODE="sigmo-rhiz"
AI_HOST_NODE="ark-rhiz"
SOURCE_NODE="rhiz-ueth"
SOURCE_NODE_ALT_EXPECTED="sigmo-rhiz"
TARGET_NODE="ark-rhiz"

# Instances
SOURCE_VM="niurk-21"
SOURCE_VM_IP="192.168.0.21"

TARGET_VM="niurk-42"
TARGET_VM_IP="192.168.0.42"

LEGACY_VM="niurk-19"
LEGACY_VM_IP="192.168.0.124"

LLAMA_GPU_CONTAINER="llama-gpu"
LLAMA_GPU_IP="192.168.0.125"

AI_CONTAINER="${AI_CONTAINER:-niurk-ai-rocm}"
AI_CONTAINER_IP="${AI_CONTAINER_IP:-}"
AI_CONTAINER_IMAGE="${AI_CONTAINER_IMAGE:-ubuntu:24.04}"

# Model/AI runtime
HOST_MODEL_DIR="${HOST_MODEL_DIR:-/srv/models}"
CONTAINER_MODEL_DIR="${CONTAINER_MODEL_DIR:-/models}"
DMR_PORT="${DMR_PORT:-12434}"
VLLM_PORT="${VLLM_PORT:-8000}"
VLLM_MODEL="${VLLM_MODEL:-Qwen/Qwen2.5-Coder-1.5B-Instruct}"
VLLM_MAX_MODEL_LEN="${VLLM_MAX_MODEL_LEN:-4096}"
VLLM_GPU_MEMORY_UTILIZATION="${VLLM_GPU_MEMORY_UTILIZATION:-0.82}"
DOCKER_MODEL_RUNNER_MODEL="${DOCKER_MODEL_RUNNER_MODEL:-ai/smollm2:360M-Q4_K_M}"
ROCM_RENDER_NODE="${ROCM_RENDER_NODE:-/dev/dri/renderD128}"
ROCM_KFD_NODE="${ROCM_KFD_NODE:-/dev/kfd}"

# Target VM project roots already exist on VM; do not copy them by default.
PROJECT_ROOTS="${PROJECT_ROOTS:-/rhiz /srv /opt /home/kobalt}"

# Health thresholds
MAX_IOWAIT_PCT="${MAX_IOWAIT_PCT:-30}"
MAX_SWAP_USED_PCT="${MAX_SWAP_USED_PCT:-50}"
MIN_TARGET_FREE_GIB="${MIN_TARGET_FREE_GIB:-4}"
MAX_LOAD_PER_CPU="${MAX_LOAD_PER_CPU:-2.5}"

# Network endpoints consumed by target services
DMR_BASE_URL="${DMR_BASE_URL:-http://${AI_CONTAINER}:${DMR_PORT}}"
VLLM_BASE_URL="${VLLM_BASE_URL:-http://${AI_CONTAINER}:${VLLM_PORT}/v1}"
OPENAI_BASE_URL="${OPENAI_BASE_URL:-${VLLM_BASE_URL}}"
OPENAI_API_KEY="${OPENAI_API_KEY:-local-niurk}"

# Namespaces
NIURK_IDENTITY_REALM="rhiz/niurk"
NIURK_SERVICE_REALM="rhiz/services"
NIURK_MODEL_REALM="rhiz/models"
NIURK_STORAGE_REALM="rhiz/storage"
NIURK_AUTH_REALM="rhiz/auth"
