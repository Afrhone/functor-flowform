# Optional identity/auth variables.
# Keep secrets out of git and out of the bundle once configured.

NIURK_OPERATOR_USER="kobalt"
NIURK_FIDO_REQUIRED="0"
NIURK_FIDO_KEY_LABEL="kobalt-rhiz-fido"
NIURK_ALLOWED_SSH_PRINCIPALS="kobalt"
NIURK_SSH_CA_PUBKEY_FILE="$HOME/.ssh/rhiz_ca.pub"

# Optional OIDC/keycloak/authelia/auth gateway integration.
NIURK_OIDC_ISSUER=""
NIURK_OIDC_CLIENT_ID=""
NIURK_OIDC_CLIENT_SECRET_FILE="/run/secrets/niurk_oidc_client_secret"

# Trust handshake namespace claim.
NIURK_NAMESPACE_CLAIM="rhiz/niurk"
NIURK_TARGET_CLAIM="host:ark-rhiz/vm:niurk-42/container:niurk-ai-rocm"
